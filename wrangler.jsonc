{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "icse-status",
  "main": "src/index.ts",
  "compatibility_date": "2026-06-18",
  "observability": {
    "enabled": true
  },
  "assets": {
    "binding": "ASSETS",
    "directory": "./public",
    "not_found_handling": "single-page-application"
  },
  "triggers": {
    "crons": ["*/15 * * * *"]
  },
  "kv_namespaces": [
    {
      "binding": "STATUS_KV",
      "id": "04f61ffbce75416e9375c644ca7899cd"
    }
  ],
  "routes": [
    {
      "pattern": "status.securityexcellence.net",
      "custom_domain": true
    }
  ]
}
